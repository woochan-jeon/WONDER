# Postgres connection string. On Vercel, add a Vercel Postgres (Neon) storage
# instance from the project's Storage tab — it injects this automatically.
# For local dev, use the same hosted DATABASE_URL (`vercel env pull` fetches it).
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# No accounts — anyone with the link can use every channel.

# Google Cloud OAuth client credentials, used to connect the team's shared Google Calendar/Drive.
# See README.md "Google Calendar 연동 설정" for step-by-step instructions.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/oauth/callback"

# Anthropic API key, used to auto-summarize new Gemini meeting minutes (from the
# Drive "Meet Recordings" folder) into agenda/decision pairs for # 회의 아카이브.
# Get one at https://console.anthropic.com/settings/keys. Optional — without it,
# the archive channel just stops picking up new meetings automatically.
ANTHROPIC_API_KEY=""

# Slack App OAuth client credentials, used to connect a Slack workspace so tasks
# can be sent to a chosen channel from # 할일. See README.md "Slack 연동 설정".
# Optional — without these, the "슬랙 연결" button and channel picker just don't appear.
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="http://localhost:3000/api/slack/oauth/callback"
